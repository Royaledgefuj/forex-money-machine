generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int          @id @default(autoincrement())
  email          String       @unique
  passwordHash   String
  name           String
  role           String       // "admin" | "student"
  status         String       @default("Active") // Active | Pending | Suspended
  membershipTier String       @default("Free") // Free | Silver | Gold | Platinum
  coursesCount   Int          @default(0)
  joinedAt       DateTime     @default(now())
  signalsAccess  Boolean      @default(false)
  payments       Payment[]
  enrollments    Enrollment[]
  signalProofs   SignalProof[]
  certificates   Certificate[]
}

model Course {
  id          Int          @id @default(autoincrement())
  name        String
  category    String
  price       String
  students    Int          @default(0)
  status      String       @default("Draft") // Published | Draft
  lessons     Lesson[]
  enrollments Enrollment[]
  payments    Payment[]
}

model Enrollment {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId   Int
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress   Int      @default(0)
  completed  Boolean  @default(false)
  source     String   // "membership" | "purchase"
  enrolledAt DateTime @default(now())

  @@unique([userId, courseId])
}

model Lesson {
  id       Int    @id @default(autoincrement())
  courseId Int
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title    String
  fileName String
  filePath String
  size     String
  duration String @default("—")
}

model LiveClass {
  id        Int    @id @default(autoincrement())
  title     String
  when      String
  platform  String
  attendees Int    @default(0)
}

model Announcement {
  id       Int      @id @default(autoincrement())
  title    String
  message  String   @default("")
  audience String
  sentAt   DateTime @default(now())
}

model Payment {
  id       Int      @id @default(autoincrement())
  student  String
  course   String
  method   String
  amount   String
  status   String   // Paid | Pending | Refunded
  date     DateTime @default(now())
  userId   Int?
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  courseId Int?
  courseRef Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)
  proofUrl  String?
  reference String?
}

model PaymentMethod {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  instructions String
  active       Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
}

model SignalProof {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  broker      String
  amount      String
  proofUrl    String
  status      String   @default("Pending") // Pending | Approved | Rejected
  submittedAt DateTime @default(now())
}

model Resource {
  id         Int      @id @default(autoincrement())
  name       String
  type       String
  tier       String   // Silver | Gold | Platinum
  version    String   @default("v1.0")
  fileName   String
  filePath   String
  size       String
  uploadedAt DateTime @default(now())
}

model Certificate {
  id                Int      @id @default(autoincrement())
  userId            Int
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentName       String
  programName       String
  batchName         String
  completionDate    String
  certificateNumber String   @unique
  issuedAt          DateTime @default(now())
}

model Broker {
  id         Int    @id @default(autoincrement())
  name       String
  clicks     Int    @default(0)
  regs       Int    @default(0)
  conv       String @default("0%")
  commission Int    @default(0)
  status     String @default("Active")
}

model Ticket {
  id      Int    @id @default(autoincrement())
  student String
  subject String
  status  String @default("Open") // Open | Resolved
  date    DateTime @default(now())
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  text      String
  createdAt DateTime @default(now())
}
